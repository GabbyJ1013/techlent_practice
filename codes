import torch
from typing import List

def no_repeat_ngram_processor(ngram_size: int):
    """
    Replicates HuggingFace's no_repeat_ngram_size logic exactly.
    Source: transformers/generation/logits_process.py NoRepeatNGramLogitsProcessor
    https://github.com/huggingface/transformers/blob/main/src/transformers/generation/logits_process.py
    """
    def processor(token_ids: List[int], logits: torch.Tensor) -> torch.Tensor:
        if len(token_ids) < ngram_size - 1:
            return logits
        prefix = tuple(token_ids[-(ngram_size - 1):])
        for i in range(len(token_ids) - ngram_size + 1):
            if tuple(token_ids[i : i + ngram_size - 1]) == prefix:
                logits[token_ids[i + ngram_size - 1]] = float("-inf")
        return logits
    return processor



def min_length_processor(min_len: int, eos_token_id: int):
    """
    Replicates HuggingFace MinLengthLogitsProcessor.
    Source: transformers/generation/logits_process.py MinLengthLogitsProcessor
    """
    def processor(token_ids: List[int], logits: torch.Tensor) -> torch.Tensor:
        if len(token_ids) < min_len:
            logits[eos_token_id] = float("-inf")
        return logits
    return processor



