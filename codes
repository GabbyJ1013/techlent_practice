import os, torch
os.environ["CUBLAS_WORKSPACE_CONFIG"] = ":4096:8"
torch.manual_seed(42)
torch.cuda.manual_seed_all(42)
torch.use_deterministic_algorithms(True, warn_only=True)

from vllm import LLM, SamplingParams
from transformers import BartTokenizerFast, BartForConditionalGeneration
from typing import List

# ── Load generation config from saved model (single source of truth) ─────────
_cfg = BartForConditionalGeneration.from_pretrained("./cps-bart").generation_config
EOS  = _cfg.eos_token_id or 2

# ── Custom LogitsProcessor: exact replica of HF NoRepeatNGramLogitsProcessor ─
def no_repeat_ngram(n: int):
    def processor(token_ids: List[int], logits: torch.Tensor) -> torch.Tensor:
        if len(token_ids) >= n - 1:
            prefix = tuple(token_ids[-(n - 1):])
            for i in range(len(token_ids) - n + 1):
                if tuple(token_ids[i: i + n - 1]) == prefix:
                    logits[token_ids[i + n - 1]] = float("-inf")
        return logits
    return processor

# ── MinLength processor: blocks EOS until min_length tokens generated ─────────
def min_length_proc(min_len: int, eos_id: int):
    def processor(token_ids: List[int], logits: torch.Tensor) -> torch.Tensor:
        if len(token_ids) < min_len:
            logits[eos_id] = float("-inf")
        return logits
    return processor

# ── vLLM engine ───────────────────────────────────────────────────────────────
llm = LLM(
    model="./cps-bart",
    dtype="float32",
    seed=42,
    enforce_eager=True,
    max_model_len=1024,
    gpu_memory_utilization=0.88,
)

# ── SamplingParams — every param mirrored from generation_config ──────────────
params = SamplingParams(
    temperature=0.0,
    use_beam_search=True,
    best_of=_cfg.num_beams,
    length_penalty=_cfg.length_penalty,
    max_tokens=_cfg.max_new_tokens or 64,
    early_stopping=True,
    stop_token_ids=[EOS],
    logits_processors=[
        no_repeat_ngram(_cfg.no_repeat_ngram_size),
        min_length_proc(_cfg.min_length or 0, EOS),
    ],
)

# ── Tokenizer: truncate inputs before passing to vLLM ────────────────────────
tok = BartTokenizerFast.from_pretrained("./cps-bart")

def _truncate(text: str) -> str:
    """Tokenize → decode at 1024 limit so vLLM sees the same input_ids as HF."""
    ids = tok.encode(text, max_length=1024, truncation=True)
    return tok.decode(ids, skip_special_tokens=False)

def vllm_summarize(texts: list[str]) -> list[str]:
    truncated = [_truncate(t) for t in texts]
    outputs = llm.generate(truncated, params)
    return [o.outputs[0].text.strip() for o in outputs]











