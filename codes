import re
from functools import reduce

FILLERS = r'\b(um+|uh+|hmm+|yeah|yep|okay|ok|right|so|like|basically|actually|you know|I mean|alright)\b'

BOILERPLATE = [
    r'thank you for (?:calling|contacting|reaching out)[^.]*\.',
    r'(?:how (?:can|may) I (?:help|assist) you)[^?]*\?',
    r'(?:is there anything else)[^?]*\?',
    r'have a (?:great|good|wonderful|nice) (?:day|evening|morning)[^.]*\.',
    r'(?:please )?hold (?:on )?(?:for )?(?:a )?(?:moment|minute|second)[^.]*\.',
    r'I(?:\'ll| will) (?:put you on |place you on )?hold[^.]*\.',
]

def clean_transcript(text: str) -> str:
    text = re.sub(r'\[?(?:Agent|Customer|Rep|Caller)[^\]]*\]?:?\s*', '', text, flags=re.IGNORECASE)
    text = re.sub(r'\b\d{2}:\d{2}(:\d{2})?\b', '', text)            # timestamps
    text = re.sub(r'\b\d{4,}\b', '[NUM]', text)                    # long numbers / PII
    text = reduce(lambda t, p: re.sub(p, '', t, flags=re.IGNORECASE), BOILERPLATE, text)
    text = re.sub(FILLERS, '', text, flags=re.IGNORECASE)
    text = re.sub(r'\b(\w+)( \1\b)+', r'\1', text, flags=re.IGNORECASE) # stutters
    text = re.sub(r'[^\w\s.,!?\'"-]', '', text)                     # junk chars
    return re.sub(r'\s+', ' ', text).strip()

def smart_truncate(text: str, tok, max_tokens: int = 1024) -> str:
    """If still over limit after cleaning: keep first 60% + last 40% (preserve resolution)."""
    ids = tok.encode(text)
    if len(ids) <= max_tokens:
        return text
    keep_head = int(max_tokens * 0.6)
    keep_tail = max_tokens - keep_head
    trimmed = ids[:keep_head] + ids[-keep_tail:]
    return tok.decode(trimmed, skip_special_tokens=True)

# Full pipeline
def prepare(text: str, tok) -> str:
    return smart_truncate(clean_transcript(text), tok)
