tok = BartTokenizerFast.from_pretrained("./cps-bart")

def generate(transcripts: list[str]) -> list[str]:
    inputs = tok(transcripts, max_length=1024, truncation=True,
                 padding=False, return_tensors="pt")
    # Decode input_ids back to string — vLLM re-tokenizes internally
    texts = tok.batch_decode(inputs["input_ids"], skip_special_tokens=False)
    outputs = llm.generate(texts, params)
    return [o.outputs[0].text.strip() for o in outputs]







